# Feature Flags for Development Logging
# These flags control whether logging code is included in the build.
# When disabled in production, Vite will completely eliminate the logging code (dead code elimination).

# Enable debug logging (console.log, console.info, console.warn)
# Set to 'true' to enable, or leave unset/false for production
VITE_ENABLE_DEBUG_LOGS=true

# Enable trace logging (console.trace)
# Set to 'true' to enable detailed trace logs
VITE_ENABLE_TRACE_LOGS=false

# Enable performance logging
# Set to 'true' to enable performance measurement logs
VITE_ENABLE_PERF_LOGS=false

# Notes:
# - These are checked at BUILD TIME, not runtime
# - Vite will tree-shake disabled logging code in production builds
# - All logging is enabled by default in development (import.meta.env.DEV)
# - For production, create a .env.production file with all flags set to false or omitted
